# Skopíruj tento súbor ako .env a doplň reálne hodnoty.
# Súbor .env NESMIE byť commitnutý do gitu!

# Firebase (Firebase Console → Project Settings → Your apps → Web)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here
FIREBASE_PROJECT_ID=vyjadreniaelprokan
FIREBASE_AUTH_DOMAIN=vyjadreniaelprokan.firebaseapp.com
FIREBASE_STORAGE_BUCKET=vyjadreniaelprokan.firebasestorage.app

# Supabase (Supabase Dashboard → Project → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API URL
API_BASE_URL=https://your-backend.railway.app/api/v1
